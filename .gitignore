# === Third-party tool/download directories (large, not our source) ===
# First-level scripts in tools/ are repository source and must be versioned. Bundled/downloaded
# runtimes belong in their own subdirectories and remain ignored.
tools/*/

# === Unpacked game data (copyrighted, regenerated) ===
work/modded_unpack/
work/external/
work/game-file-backups/

# === Raw extracted game data (copyrighted) and backups of game files ===
extracted/
backups/

# === Extracted sprite/G2D art (copyrighted game asset, regenerated via FF16Tools) ===
work/sprite-extract/system/
work/sprite-extract/**/*.dat
work/sprite-extract/**/*.bin
work/sprite-extract/**/*.dds
work/sprite-extract/**/*.png
# keep work/sprite-extract/g2d_manifest.json (small derived index, safe to track)

# === Large derived data dumps (regenerated from the game) ===
work/*.sqlite
work/nxd_extract/
work/ability_en/
work/nxd_more/
work/nxd_out/
work/nxd_proof/

# === Local live-test rollback binaries (large, machine-specific, not evidence owners) ===
# Keep the timestamped Markdown manifest/settings/log that describe each rollback point. The copied
# DLL/PDB and automatic pre-restore container are disposable safety backups and make the Codex Git
# preview spawn one no-index diff process per binary in a long-running worktree.
work/*-pre-dll.dll
work/*-pre-pdb.pdb
work/*-before-restore.png

# === .NET build output (Reloaded-II code mod) ===
codemod/**/bin/
codemod/**/obj/
codemod/**/_build/

# === Regenerable reviewer outputs (re-created by running work/*_check.py) ===
work/claude-*.json
work/claude_sweep_*.txt
work/sim_inputs_*_stats.json

# === Scratch / throwaway workspaces (e.g. validation runs) ===
tmp/*
!tmp/.keep

# === OS / editor cruft ===
Thumbs.db
ehthumbs.db
Desktop.ini
*.tmp
*.swp
.DS_Store
__pycache__/
*.pyc
.vscode/
.idea/

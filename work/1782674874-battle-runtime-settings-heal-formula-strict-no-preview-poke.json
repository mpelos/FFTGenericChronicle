{
  "_note": "LIVE APPLY - strict healing execution formula without global preview poke. Purpose: prove explicit action healing can be formula-rewritten through +0x1C6 while Regen/passive HP-credit does not get caught. Expected test action: Agrias -> Ramza same healing action observed as action id 159. Preview remains natural; execution should heal by min(missing HP, a.ma * 10 + t.faith).",

  "RewriteObservedDamage": false,
  "RewriteObservedHealing": true,
  "RewriteObservedMpLoss": false,
  "RewriteObservedMpGain": false,
  "DryRunRewrites": false,

  "RewriteConditionFormula": "event.isHealing && a.sourceImmediate && action.sourceImmediate && action.currentActiveAction && action.freshActiveAction && action.actionId == 159 && action.currentCreditCacheMatch",
  "FinalDamageFormula": "-min(t.maxHp - previousHp, a.ma * 10 + t.faith)",
  "FormulaTraceVariables": [
    { "Name": "trace.isHealing", "Formula": "event.isHealing" },
    { "Name": "trace.actionId", "Formula": "action.actionId" },
    { "Name": "trace.freshActive", "Formula": "action.freshActiveAction" },
    { "Name": "trace.activeAgeMs", "Formula": "action.activeActionAgeMs" },
    { "Name": "trace.creditCache", "Formula": "action.currentTargetCacheCredit" },
    { "Name": "trace.vanillaHealing", "Formula": "vanillaHealing" },
    { "Name": "trace.attackerMa", "Formula": "a.ma" },
    { "Name": "trace.targetFaith", "Formula": "t.faith" },
    { "Name": "trace.targetMissingHp", "Formula": "t.maxHp - previousHp" },
    { "Name": "trace.expectedHeal", "Formula": "min(t.maxHp - previousHp, a.ma * 10 + t.faith)" }
  ],


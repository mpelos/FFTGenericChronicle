  "PreClampDamageRewriteLogOnly": false,
  "PreClampManagedCallbackEnabled": false,
  "PreClampManagedCallbackForcedDebit": -1,
  "PreClampManagedCallbackActorFormulaEnabled": false,
  "PreClampManagedCallbackPaMultiplier": 0,
  "PreClampManagedCallbackFormulaMinDamage": 1,

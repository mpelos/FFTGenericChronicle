  "PreClampManagedCallbackStackScanBytes": 512,
  "PreClampFormulaPlanEnabled": false,

  "CalcEntryProbeEnabled": false,
  "CalcEntryProbeRva": 3185220,

  "ItemTableEvadeZeroEnabled": true,

    { "Name": "dcl.isThrust", "Formula": "aslot.weapon.category_knife || aslot.weapon.category_polearm" },
    { "Name": "dcl.isMissile", "Formula": "aslot.weapon.category_bow || aslot.weapon.category_crossbow || aslot.weapon.category_gun" },
    { "Name": "dcl.typeIndex", "Formula": "if(dcl.isCut, 0, if(dcl.isThrust, 1, if(dcl.isMissile, 3, 2)))" },
    { "Name": "dcl.woundNum", "Formula": "if(dcl.isCut, 3, if(dcl.isThrust, 2, 1))" },
    { "Name": "dcl.woundDen", "Formula": "if(dcl.isCut, 2, 1)" },
    { "Name": "armor.plate", "Formula": "tslot.body.category_armor && tslot.body.armorHpBonus >= 60" },
    { "Name": "armor.mail", "Formula": "tslot.body.category_armor && tslot.body.armorHpBonus >= 40 && tslot.body.armorHpBonus < 60" },
    { "Name": "armor.robe", "Formula": "tslot.body.category_robe" },
    { "Name": "armor.classIndex", "Formula": "if(armor.plate, 0, if(armor.mail, 1, if(armor.robe, 3, 2)))" },
    { "Name": "dcl.st", "Formula": "a.rawPa + 4" },
    { "Name": "dcl.base", "Formula": "if(dcl.isThrust, tableClamp(gurpsThr, dcl.st), tableClamp(gurpsSw, dcl.st))" },
    { "Name": "dcl.wmod", "Formula": "aslot.weapon.weaponPower" },
    { "Name": "dcl.gross", "Formula": "dcl.base + dcl.wmod" },
    { "Name": "dcl.dr", "Formula": "matrixClamp(drMatrix, armor.classIndex, dcl.typeIndex)" },
    { "Name": "dcl.penFloor", "Formula": "mulDiv(dcl.gross, 200, 1000)" },
    { "Name": "dcl.penetrating", "Formula": "max(dcl.penFloor, dcl.gross - dcl.dr)" },
    { "Name": "dcl.wounded", "Formula": "mulDiv(dcl.penetrating, dcl.woundNum, max(1, dcl.woundDen))" },
    { "Name": "dcl.traitPermille", "Formula": "760 + mulDiv(a.brave, 590, 100)" },
    { "Name": "dcl.weaponModel", "Formula": "max(1, mulDiv(dcl.wounded, dcl.traitPermille, 1000))" }
  ],
  "DclDamageFormula": "if(action.type == 1 && dcl.oldDebit > 0, dcl.weaponModel, dcl.oldDebit)",

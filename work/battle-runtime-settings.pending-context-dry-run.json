{
  "_note": "Live-safe proof that pending-action context reaches BattleFormulaEngine. DryRunRewrites prevents HP writes; Cross Slash act=258 should report finalDamage=vanillaDamage+10 only when attacker/action source is pending-clear.",
  "DryRunRewrites": true,
  "RewriteObservedDamage": true,
  "RewriteObservedHealing": false,
  "RewriteObservedMpLoss": false,
  "RewriteObservedMpGain": false,
  "AffectAllies": true,
  "AffectFoes": true,
  "FinalDamageFormula": "if(event.isDamage && attacker.sourcePending && action.sourcePending && action.id == 258, vanillaDamage + 10, vanillaDamage)",
  "RewriteConditionFormula": "event.isDamage",
  "LogResolvedRuntimeContext": true,
  "FormulaTraceVariables": [
    { "Name": "trace.pending", "Formula": "attacker.sourcePending" },
    { "Name": "trace.actionPending", "Formula": "action.sourcePending" },
    { "Name": "trace.actionId", "Formula": "action.id" },
    { "Name": "trace.batchEvent", "Formula": "action.batchEvent" },
    { "Name": "trace.damageCacheMatch", "Formula": "action.damageCacheMatch" },
    { "Name": "trace.observedHpLoss", "Formula": "action.observedHpLoss" }
  ],
  "ResolveAttackerByCt": true,
  "ResolveAttackerByLowCtFallback": true,
  "CtDropWindowMs": 7000,
  "CtLowFallbackMaxCt": 25,
  "CtLowFallbackWindowMs": 7000,
  "LogCtResolutionDiagnostics": true,
  "LogAttackerCandidates": true,
  "HookRegisterProbe": false,
  "HookRegisterProbeOnHpEvent": false,
  "HookRegisterProbeOnMpEvent": false,
  "HookRegisterProbeOnCtDrop": false,
  "ActorProbeOnEvent": false,
  "LogPendingActionCandidatesOnEvent": true,
  "LogAllPendingActionCandidates": false,
  "PendingActionCandidateMaxUnits": 16,
  "LogActionStateChanges": true,
  "TrackPendingActions": true,
  "PendingActionResolveWindowMs": 5000,
  "PendingActionMaxBatchEvents": 16,
  "PendingActionStaleMs": 30000,
  "LogUnknownFieldDiffs": false,
  "CaptureStructOnDeath": false,
  "CauseDeathOnZeroHp": false,
  "MinHpFloor": 0,
  "UnitPollIntervalMs": 25,
  "MaxTrackedBattleUnits": 64
}

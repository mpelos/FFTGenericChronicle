    "dancer_hp_tick": "min(floor(round(percent * target_max_hp, 6)), per_tick_cap, floor(round(K * dancer_PA * 0.60, 6)))",
    "dancer_hp_pulse": "min(floor(round(percent * target_max_hp, 6)), pulse_cap, floor(round(K * dancer_PA * 0.60, 6)))",
    "witch_hunt_mp_tick": "min(target_current_mp, 12, floor(round(1.90 * dancer_MA * 0.60, 6)))",

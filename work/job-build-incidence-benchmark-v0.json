{
  "schema_version": "job-build-incidence-benchmark-v0",
  "status": "accepted",
  "date": "2026-06-20",
  "source_docs": [
    "docs/job-balance/01-cross-job-build-principles.md",
    "docs/job-balance/02-job-design-protocol.md",
    "docs/job-balance/03-job-roster-and-role-map.md",
    "docs/job-balance/07-validation-infrastructure-roadmap.md"
  ],
  "purpose": "Pinned input bundle for T2 build-incidence matrix schema and required coverage.",
  "thresholds": {
    "reaction_support_movement": {
      "warning_exclusive_gt": 0.35,
      "fail_exclusive_gt": 0.5
    },
    "secondary": {
      "warning_exclusive_gt": 0.35,
      "fail_exclusive_gt": 0.5
    },
    "equipment_unlock": {
      "warning_exclusive_gt": 0.35,
      "fail_exclusive_gt": 0.5
    }
  },
  "record_statuses": {
    "open_slot": {
      "counted": false,
      "meaning": "Required coverage slot exists but no accepted build fills it yet."
    },
    "draft_candidate": {
      "counted": false,
      "meaning": "Plausible build candidate exists but has not been accepted."
    },
    "accepted_provisional": {
      "counted": true,
      "meaning": "Accepted for provisional design and counted in provisional incidence runs."
    },
    "accepted_final": {
      "counted": true,
      "meaning": "Accepted after all required validation gates."
    },
    "retired": {
      "counted": false,
      "meaning": "Superseded or rejected record retained for audit."
    }
  },
  "counted_slots": [
    "secondary",
    "reaction",
    "support",
    "movement",
    "equipment_unlocks"
  ],
  "required_coverage": {
    "primary_roles": [
      "melee-physical",
      "ranged-physical",
      "caster-offense",
      "caster-support",
      "controller",
      "hybrid",
      "performer",
      "specialist",
      "late-reward",
      "protagonist"
    ],
    "armor_profiles": [
      "plate",
      "mail",
      "leather",
      "cloth"
    ],
    "physical_damage_modes": [
      "swing",
      "thrust",
      "crush",
      "missile"
    ],
    "nonphysical_pressure": [
      "magic",
      "spirit_status"
    ],
    "sensitivity_tags": [
      "Brave",
      "Faith",
      "Speed"
    ],
    "mandatory_phases": [
      "late",
      "stress"
    ],
    "optional_phases": [
      "early",
      "mid"
    ]
  },
  "coverage_semantics": {
    "missing_required_coverage": "marginal_per_dimension",
    "coverage_presence_record_subset": "all_records_including_open_slot",
    "incidence_record_subset": "records_where_record_statuses_status_counted_is_true",
    "phase_coverage_scope": "mandatory_phases_only"
  },
  "anti_bias_rules": [
    "Do not over-represent already dominant builds.",
    "Do not under-represent weak roles.",
    "Do not count small equipment variants as separate build identities unless tactical identity changes.",
    "Do not omit armor classes or damage modes that make a favored global piece look less universal.",
    "Do not curate the benchmark set to pass a favored secondary, reaction, support, movement, or equipment unlock."
  ],
  "build_record_schema": {
    "id": "stable snake-case id",
    "status": "open_slot | draft_candidate | accepted_provisional | accepted_final | retired",
    "phase": "early | mid | late | stress",
    "primary_role": "role taxonomy value",
    "active_job": "job name or TBD",
    "coverage": {
      "armor_profile": "plate | mail | leather | cloth | TBD",
      "damage_modes": [
        "swing | thrust | crush | missile | magic | spirit_status | TBD"
      ],
      "pressure_tags": [
        "freeform controlled tag"
      ],
      "sensitivity_tags": [
        "Brave | Faith | Speed"
      ]
    },
    "slots": {
      "secondary": "skillset name or NONE or TBD",
      "reaction": "skill name or NONE or TBD",
      "support": "skill name or NONE or TBD",
      "movement": "skill name or NONE or TBD",
      "equipment_unlocks": [
        "support-granted equipment unlocks"
      ]
    },
    "counting": {
      "include": false,
      "reason": "why included or ignored"
    },
    "flags": [
      "optional flags such as protagonist_exception or shared_gender_pair"
    ],
    "notes": "short explanation"
  },
  "counting_contract": {
    "counting_source_of_truth": "record_statuses[status].counted",
    "per_record_counting_include_must_equal_status_counted": true,
    "counting_divergence": "hard_validation_error",
    "incidence_scope": {
      "phases": [
        "late",
        "stress"
      ],
      "denominator": "counted builds in late or stress phase",
      "numerator": "counted late or stress builds whose relevant slot contains the value",
      "array_slot_dedupe_per_build": true,
      "threshold_comparison": "raw_fraction_exclusive_greater_than"
    },
    "slot_tokens": {
      "none": "NONE",
      "unknown": "TBD",
      "none_behavior": "excluded_from_incidence",
      "tbd_in_counted_record": "hard_validation_error"
    },
    "empty_denominator": {
      "canonical_token": "NO_COUNTED_BUILDS",
      "incidence_tables": "empty",
      "threshold_warnings": 0,
      "threshold_failures": 0
    },
    "canonical_output": {
      "sort_rows": "alphabetical_by_key",
      "ignored_records_by_reason_key": "exact_counting_reason_string",
      "display_percentage_decimals": 6,
      "comparison_basis": "raw_numerator_denominator_fraction"
    }
  },
  "special_counting_rules": {
    "t2_1_population": "only accepted_provisional or accepted_final records; no draft_candidate placeholders",
    "ramza_chapter4": "same table with protagonist_exception flag",
    "bard_dancer_shared_globals": "count shared reaction/support/movement global pieces once"
  },

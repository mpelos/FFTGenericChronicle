    "docs/job-balance/32-campaign-artifacts-provisional-v0.md",
    "docs/job-balance/36-action-economy-model-schema.md"
  ],
  "formula_contract": {
    "normalization": "single_tactical_action_grant_window",
    "anti_recursion": "trigger_context=granted_action fails when block_granted_action_grants=true",
    "resolution_order": [
      "recursion_blocked",
      "source_cannot_act",
      "target_cannot_receive",
      "per_target_cap",
      "party_cap",
      "success"
    ],
    "source_action_spent": "counted when the attempt occurs, whether it succeeds or fails",
    "net_action_delta": "successful_grants - total_source_actions_spent",
    "caps": "successful grants increment party and target counts"
  },
  "scenarios": [
    {
      "scenario_id": "t10_quick_one_for_one",
      "model": "action_economy",
      "policy": {
        "party_grant_cap": 2,
        "per_target_grant_cap": 1,
        "block_granted_action_grants": true
      },
      "units": [
        {
          "unit_id": "time_mage",
          "can_act": true,
          "can_receive_grant": true
        },
        {
          "unit_id": "knight",
          "can_act": true,
          "can_receive_grant": true
        }
      ],
      "events": [
        {
          "event_id": "quick_knight",
          "source_unit_id": "time_mage",
          "target_unit_id": "knight",
          "trigger_context": "natural_action",
          "source_action_spent": 1
        }
      ],
      "expected": {
        "successful_grants": 1,
        "failed_grants": 0,
        "total_source_actions_spent": 1,
        "net_action_delta": 0,
        "party_grant_count": 1,
        "target_grant_counts": {
          "knight": 1
        },
        "event_outcomes": [
          "quick_knight:success"
        ],
        "failure_reasons": []
      }
    },

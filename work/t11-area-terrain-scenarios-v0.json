{
  "schema_version": "t11-area-terrain-scenarios-v0",
  "status": "accepted",
  "date": "2026-06-21",
  "source_docs": [
    "docs/job-balance/21-summoner-geomancer-v1-proposal.md",
    "docs/job-balance/24-dragoon-samurai-v1-proposal.md",
    "docs/job-balance/26-bard-dancer-v1-proposal.md",
    "docs/job-balance/30-roster-completion-and-infra-sprint-plan.md",
    "docs/job-balance/31-campaign-gameplay-validation-v1.md",
    "docs/job-balance/32-campaign-artifacts-provisional-v0.md",
    "docs/job-balance/34-area-terrain-model-schema.md"
  ],
  "formula_contract": {
    "normalization": "per_action_targeting_snapshot",
    "candidate_validity": "can_target_panel and line_of_effect and terrain_requirement_satisfied",
    "shape_single": "same x/y panel within vertical_tolerance",
    "shape_diamond": "manhattan distance <= radius within vertical_tolerance",
    "shape_square": "chebyshev distance <= radius within vertical_tolerance",
    "shape_line": "axis-aligned ray from origin through target panel; origin panel excluded; distance from origin is inclusive at <= length; vertical_tolerance compares unit z to origin z",
    "shape_mapwide": "all targetable units in snapshot",
    "target_groups": [
      "enemies",
      "allies",
      "all_units"
    ],
    "ally_safe": "for all_units rows, allied units are excluded when ally_safe=true",
    "score": "sum(priority * enemy_weight for enemies plus priority * ally_weight for allies)",
    "selection": "highest score among valid candidates; earliest candidate wins ties",
    "no_selection": "no valid candidate -> no_valid_candidate; best score below minimum_score_to_select -> below_minimum_score",
    "terrain_scopes": [
      "target_panel",
      "origin_panel"
    ],
    "terrain_invalid_policy": "exclude",
    "numeric_comparison": {
      "float_decimals": 6
    }
  },

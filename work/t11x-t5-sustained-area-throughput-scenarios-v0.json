{
  "schema_version": "t11x-t5-sustained-area-throughput-scenarios-v0",
  "status": "accepted",
  "date": "2026-06-21",
  "source_docs": [
    "docs/job-balance/11-ct-delay-model-schema.md",
    "docs/job-balance/26-bard-dancer-v1-proposal.md",
    "docs/job-balance/34-area-terrain-model-schema.md",
    "docs/job-balance/40-sustained-area-throughput-composition-schema.md"
  ],
  "formula_contract": {
    "normalization": "sustained_area_effect_over_tick_schedule",
    "tick_schedule": "ticks start at start_tick + first_tick_delay, repeat every tick_interval, and occur while tick <= start_tick + duration_ticks",
    "interrupt_policy": "if interrupt_tick exists, ticks at tick >= interrupt_tick are canceled",
    "unit_activity_window": "active_start_tick <= tick < active_expire_tick when active_expire_tick exists",
    "area_membership": "mapwide, single, diamond, or square shape from T11",
    "score": "per_target_value * sum(priority * team_weight) per tick",
    "target_count_cap": "if present, aggregate score is scaled by min(raw_count, cap) / raw_count",
    "total_score": "sum(per_tick_scores)"
  },

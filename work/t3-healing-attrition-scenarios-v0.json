  "external_sources": [
    {
      "id": "aerostar_battle_mechanics",
      "url": "https://gamefaqs.gamespot.com/ps/197339-final-fantasy-tactics/faqs/3876",
      "notes": [
        "Potion restores 30 HP.",
        "Hi-Potion restores 70 HP.",
        "X-Potion restores 150 HP.",
        "Phoenix Down cancels Dead and restores low random HP in vanilla."
      ]
    }
  ],
  "formula_contract": {
    "normalization": "action_normalized",
    "rounding": "floor_spell_raw_heal",
    "overheal_policy": "effective_heal=min(raw_heal,missing_hp)",
    "faith_factor_floor": 0.6,
    "spell_heal": "floor(K * MA * max(faith_factor_floor,(caster_faith/100)*(target_faith/100)))",
    "item_heal": "item_power",
    "success_chance": "fixed_1_0_in_T3_0",
    "expected_reaction_heal": "effective_heal * trigger_chance * effective_triggers",
    "effective_triggers": "min(incoming_triggers,per_round_cap)",
    "expected_reaction_resource_consumed": "trigger_chance * effective_triggers * resource_cost",
    "reaction_uses_resolved": "effective_triggers",
    "reaction_total_expected_heal": "expected_heal",
    "non_reaction_resource_consumed": "resource_cost * uses_resolved",
    "resource_limited_uses": "non_reaction_only:min(planned_uses,floor(resource_available/resource_cost))",
    "resolution_delay_ticks": "recorded_context_only_until_T5",
    "numeric_comparison": {
      "integers": [
        "raw_heal",
        "effective_heal",
        "overheal"
      ],
      "floats": [
        "expected_heal",
        "resource_consumed",
        "total_expected_heal"
      ],
      "float_decimals": 6
    },
    "cross_delivery_reliability": "not_accepted_until_T3xT5_composition"
  },
  "tokens": {
    "not_applicable": "NA"
  },

  "formula_contract": {
    "normalization": "single_healing_race",
    "active_heal_before_threat": "resolution_delay_ticks < threat_tick",
    "same_tick_policy": "unsafe_for_healing_and_revive_races_in_T3xT5_0",
    "active_heal_after_nonlethal": "delayed healing still resolves if hp_after_threat > 0",
    "active_heal_after_lethal": "delayed healing does not prevent KO if hp_after_threat <= 0 before resolution",
    "reaction_timing": "post_damage_survivor_only",
    "reaction_expected_heal": "effective_heal * trigger_chance * min(incoming_triggers, per_round_cap) if hp_after_damage > 0 else 0",
    "revive_before_death_clock": "resolution_delay_ticks < death_clock_ticks",
    "numeric_comparison": {
      "float_decimals": 6
    }
  },

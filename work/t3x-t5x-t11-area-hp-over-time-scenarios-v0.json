    "docs/job-balance/41-area-hp-over-time-composition-schema.md"
  ],
  "formula_contract": {
    "normalization": "area_hp_effect_over_tick_schedule",
    "tick_schedule": "same as T11xT5",
    "healing": "effective_heal=min(per_target_value, missing_hp)",
    "damage": "effective_damage=min(per_target_value, current_hp)",
    "ko_policy": "units at hp <= 0 are excluded from future ticks unless affects_ko=true",
    "undead_inversion": "healing becomes damage for undead if undead_inverts_healing=true",
    "area_membership": "mapwide, single, diamond, or square shape from T11",
    "total_fields": "sum raw/effective/overheal/overkill over ticks"
  },

  ],
  "formula_contract": {
    "normalization": "single_target_state_sequence",
    "eligibility": "not consumed, state in required_states, targetable, can_reach, line_of_effect, and no blocked immunity tag",
    "death_clock": "resolution_delay_ticks < death_clock_ticks; same tick is unsafe",
    "no_death_clock": "death_clock_ticks=null skips death-clock failure",
    "consumed_target": "later events fail target_consumed",
    "acting_body_policy": "created can_act is suppressed unless allow_acting_bodies=true",
    "diagnostic_allow_acting": "allow_acting_bodies=true rows are harness coverage only, not shipped-data approval"
  },
  "scenarios": [
    {
      "scenario_id": "t3x5x8_corpse_puppet_before_clock_consumes",
      "model": "ko_corpse_undead_state",
      "policy": {
        "allow_acting_bodies": false
      },
      "target": {
        "state": "ko_body",
        "death_clock_ticks": 5,
        "targetable": true,
        "can_reach": true,
        "line_of_effect": true,
        "immunity_tags": []
      },
      "events": [
        {
          "event_id": "corpse_puppet",
          "required_states": [
            "ko_body"
          ],
          "resolution_delay_ticks": 3,
          "consume_target": true,
          "blocked_by_tags": [
            "boss",
            "unique",
            "guest"
          ],
          "creates": {
            "state": "corpse_puppet",
            "control_owner": "player",
            "can_act": false,
            "targetable": true,
            "expiry_ticks": 6
          }
        }
      ],
      "expected": {
        "successful_actions": 1,
        "failed_actions": 0,
        "final_target_state": "consumed",
        "target_consumed": true,
        "consumed_count": 1,
        "created_objects": [
          "corpse_puppet:corpse_puppet:player:can_act=false:targetable=true:expiry=6"
        ],
        "same_tick_unsafe_count": 0,
        "death_clock_miss_count": 0,
        "acting_body_suppressed_count": 0,
        "event_outcomes": [
          "corpse_puppet:success"
        ],
        "failure_reasons": []
      }
    },

{
  "schema_version": "t4-accuracy-evasion-scenarios-v0",
  "status": "accepted",
  "date": "2026-06-20",
  "source_docs": [
    "docs/job-balance/06-knight-archer-v1-proposal.md",
    "docs/job-balance/07-validation-infrastructure-roadmap.md",
    "docs/job-balance/09-accuracy-evasion-model-schema.md"
  ],
  "external_sources": [
    {
      "id": "aerostar_battle_mechanics",
      "url": "https://gamefaqs.gamespot.com/ps/197339-final-fantasy-tactics/faqs/3876",
      "notes": [
        "Section 1.4 evasion formulas.",
        "Charge/Aim uses normal weapon evasion and can miss if the target panel is vacated.",
        "Jump is not evadable."
      ]
    }
  ],
  "formula_contract": {
    "rounding": "truncate_after_full_multiplication",
    "percentage_min": 0,
    "percentage_max": 100,
    "per_factor_clamp": {
      "effective_evade": "min(100, max(0, evade * evasion_multiplier))",
      "term": "100 - effective_evade",
      "applies_to": [
        "physical",
        "magical"
      ]
    },
    "final_hit_clamp": "min(100, max(0, truncated_hit))",
    "physical": {
      "front": [
        "base_hit",
        "p_class_evade",
        "p_shield_evade",
        "p_accessory_evade",
        "weapon_evade_if_enabled"
      ],
      "side": [
        "base_hit",
        "p_shield_evade",
        "p_accessory_evade",
        "weapon_evade_if_enabled"
      ],
      "rear": [
        "base_hit",
        "p_accessory_evade"
      ]
    },
    "magical": {
      "any": [
        "base_hit",
        "m_shield_evade",
        "m_accessory_evade"
      ]
    },
    "non_evadable": {
      "expected_hit": "base_hit_if_can_target_else_0"
    },
    "targeting": {
      "line_of_fire_blocked": "can_target_false_and_expected_hit_0",
      "panel_vacated_before_resolution": "can_target_false_and_expected_hit_0"
    }
  },
  "tokens": {
    "not_applicable": "NA"
  },

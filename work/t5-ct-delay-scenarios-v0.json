{
  "schema_version": "t5-ct-delay-scenarios-v0",
  "status": "accepted",
  "date": "2026-06-20",
  "source_docs": [
    "docs/job-balance/06-knight-archer-v1-proposal.md",
    "docs/job-balance/07-validation-infrastructure-roadmap.md",
    "docs/job-balance/11-ct-delay-model-schema.md",
    "work/sim-inputs-v0.2.1.json"
  ],
  "external_sources": [
    {
      "id": "aerostar_battle_mechanics",
      "url": "https://gamefaqs.gamespot.com/ps/197339-final-fantasy-tactics/faqs/3876",
      "notes": [
        "CT reaches active turn at 100.",
        "Each clocktick increases CT by Speed.",
        "Post-turn CT reduction depends on move/action choice.",
        "Slow action CTR is round-up of 100 divided by spell speed."
      ]
    }
  ],
  "formula_contract": {
    "ticks_to_turn": "0 if current_ct>=100 else ceil((100-current_ct)/speed)",
    "post_turn_ct": {
      "move_and_act": -100,
      "move_only": -80,
      "act_only": -80,
      "wait": -60
    },
    "ctr_from_spell_speed": "ceil(100/spell_speed)",
    "ticks_to_resolution": "ctr",
    "jump_ticks": "ceil(50/speed)",
    "target_safe": "ticks_to_resolution < target_ticks_to_turn",
    "same_tick_policy": "unsafe_for_panel_targeted_delayed_actions",
    "interrupts_before_resolution": "interrupt_tick < ticks_to_resolution",
    "whiff_window_ticks": "max(0,ticks_to_resolution-target_ticks_to_turn)",
    "predictability": "safe if target_safe else unsafe",
    "whiff_window_ticks_note": "lateness_magnitude_only_not_safe_unsafe_verdict"
  },
  "phase_speed_bands": {
    "early": 6,
    "mid": 7,
    "late": 8,
    "stress": 9
  },
  "scenarios": [

{
  "schema_version": "t5x-t8-timed-untargetability-scenarios-v0",
  "status": "accepted",
  "date": "2026-06-21",
  "source_docs": [
    "docs/job-balance/11-ct-delay-model-schema.md",
    "docs/job-balance/15-targeting-challenge-model-schema.md",

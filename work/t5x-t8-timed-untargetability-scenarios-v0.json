    "docs/reference/fft-vanilla-status-effect-map.md",
    "docs/job-balance/39-timed-untargetability-composition-schema.md"
  ],
  "formula_contract": {
    "normalization": "single_targeting_or_resolution_event",
    "active_window": "start_tick <= evaluation_tick < expire_tick",
    "same_tick_expiry": "expired before targeting or resolution at that tick",
    "break_events": "effects with break_on_damage or break_on_action end when a matching event tick is <= evaluation_tick",
    "candidate_eligibility": "target unit exists, target can_target, target not ai_ignored, candidate can_reach, candidate line_of_effect, and target has no active untargetable effect",
    "selection": "highest total_score; earliest eligible candidate wins ties",
    "delayed_resolution": "a delayed action resolves only if the target is targetable at resolution_tick"
  },
  "scenarios": [

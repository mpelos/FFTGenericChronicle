  "formula_contract": {
    "base_response": "armor_response[armor_class][damage_type]",
    "effective_penetration": "clamp(family_penetration + penetration_bonus, 0.0, 1.0)",
    "penetration_formula": "base + effective_penetration*(penetration_ceiling-base) if base<penetration_ceiling else base",
    "penetration_ceiling": 1.1,
    "dynamic_delta": "sum(response_delta values)",
    "composition_rule": "additive_response_delta_after_penetration",
    "unclamped_response": "penetrated_response + dynamic_delta",
    "final_response": "clamp(unclamped_response, combined_multiplier_clamp[0], combined_multiplier_clamp[1])",
    "combined_multiplier_clamp": [
      0.25,
      2.5
    ],
    "damage_per_hit": "floor(round(base_damage_per_hit * final_response, 6))",
    "total_damage": "damage_per_hit * hit_count",
    "normalization": "per_application_per_hit",
    "duration_policy": "duration_ticks_is_context_only_for_later_t6xt5_composition",
    "float_safe_floor_note": "round_to_6_before_floor_prevents_ieee_double_artifacts_like_100_times_1_15_flooring_to_114",
    "copied_policy_values_note": "armor_response_family_penetration_penetration_ceiling_and_clamp_are_copied_from_v0_2_1_and_must_be_regenerated_if_formula_policy_changes",
    "numeric_comparison": {
      "float_decimals": 6
    }
  },
  "armor_response": {
    "plate": {
      "swing": 0.65,
      "thrust": 0.65,

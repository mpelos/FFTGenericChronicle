    "work/t6-armor-response-scenarios-v0.json",
    "work/t7-enemy-offense-scenarios-v0.json"
  ],
  "formula_contract": {
    "normalization": "per_application_per_hit",
    "composition_boundary": "T7 output_per_hit is the pre-armor output consumed by T6",
    "base_response": "armor_response[armor_class][damage_type]",
    "effective_penetration": "clamp(family_penetration + penetration_bonus, 0.0, 1.0)",
    "penetration_formula": "base + effective_penetration*(penetration_ceiling-base) if base<penetration_ceiling else base",
    "penetration_ceiling": 1.1,
    "dynamic_delta": "sum(response_delta values)",
    "final_response": "clamp(penetrated_response + dynamic_delta, combined_multiplier_clamp[0], combined_multiplier_clamp[1])",
    "combined_multiplier_clamp": [
      0.25,
      2.5
    ],
    "damage_per_hit": "floor(round(output_per_hit * final_response, 6))",
    "total_damage": "damage_per_hit * hit_count",
    "no_family_policy": "resulting_family=none deals zero damage and has no armor-response matchup",
    "ratio_denominator_zero_policy": "ratio fields return 0.0 when denominator is 0",
    "numeric_comparison": {
      "float_decimals": 6
    }
  },
  "armor_response": {
    "plate": {
      "swing": 0.65,
      "thrust": 0.65,
      "crush": 1.15,
      "missile": 0.8
    },
    "mail": {

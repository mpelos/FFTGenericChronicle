  "formula_contract": {
    "base_family": "attack.weapon_family",
    "attacker_side_routine": "use the v0.2.1 family routine with attacker stats and phase-scaled WP",
    "permanent_replacement_order": "blocked permanent break effects are ignored, then unblocked permanent break/steal/disarm may replace the family or set it to none",
    "temporary_output_pressure_order": "apply output multipliers after permanent replacement",
    "effective_output_multiplier": "clamp(product(output_multiplier effects), 0.0, 1.0), or 0.0 for temporary_jam/no_family",
    "output_multiplier_stacking": "multiplicative_not_additive",
    "permanent_replacement_limit": "T7.0 assumes at most one unblocked permanent replacement effect per application; future stacked-break scenarios must define precedence before acceptance",
    "output_per_hit": "floor(round(resulting_raw_output_per_hit * effective_output_multiplier, 6))",
    "total_output": "output_per_hit * hit_count",
    "normalization": "per_application_per_hit",
    "duration_policy": "duration_ticks_is_context_only_for_later_t7xt5_composition",
    "t6xt7_hook": "record resulting_family and resulting_damage_type for later armor-response composition",
    "mandatory_piece_policy": "T2 must flag disarm, weapon-break, and anti-break support incidence before concrete job data is accepted",
    "float_safe_floor_note": "round_to_6_before_floor_prevents_ieee_double_artifacts_like_100_times_0_29_flooring_to_28",
    "copied_policy_values_note": "families_jobs_phase_wp_scalar_and_default_brave_are_copied_from_v0_2_1_and_must_be_regenerated_if_formula_policy_changes",
    "numeric_comparison": {
      "float_decimals": 6
    }
  },
  "phase_wp_scalar": {
    "early": 0.5,
    "mid": 0.75,
    "late": 1.0,

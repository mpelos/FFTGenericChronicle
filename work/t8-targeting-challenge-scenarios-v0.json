  "source_docs": [
    "docs/job-balance/06-knight-archer-v1-proposal.md",
    "docs/job-balance/07-validation-infrastructure-roadmap.md",
    "docs/job-balance/12-vanilla-skill-status-reference.md",
    "docs/job-balance/15-targeting-challenge-model-schema.md",
    "docs/reference/fft-vanilla-ability-effect-index.md",
    "docs/reference/fft-vanilla-status-effect-map.md"
  ],
  "formula_contract": {
    "normalization": "per_enemy_decision",
    "candidate_eligibility": "can_target and can_reach and line_of_effect and not ai_ignored",
    "control_override": "control_state != normal selects control_policy_candidate_id and ignores challenge for this decision",
    "control_override_eligibility": "control override is not gated by normal AI eligibility; the control policy owns the target selection",
    "hard_challenge": "if mode=hard and actor is not forced_target_immune and challenger has an eligible candidate, select the highest-scoring eligible challenger candidate",
    "hard_challenge_fallback": "forced_target_immune actors or ineligible challengers use normal scoring",
    "soft_challenge": "candidate_score = tactical_score + lethal_bonus + self_preservation_bonus + objective_bonus + challenge_bonus_if_targeting_challenger",
    "soft_challenge_bonus_type": "additive_not_multiplicative",
    "tie_breaker": "earliest candidate in scenario order",
    "duration_policy": "duration_ticks_is_context_only_for_later_t8xt5_composition",
    "mandatory_piece_policy": "T2 must flag challenge, taunt, mark, defender, and anti-targeting incidence before concrete job data is accepted"
  },

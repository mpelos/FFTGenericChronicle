  "formula_contract": {
    "normalization": "single_spell_routing_event",
    "reflect_trigger": "spell.reflectable and original_target.has_reflect",
    "candidate_eligibility": "unit exists and can_target and line_of_effect and not spell_immune and not ai_ignored",
    "selection": "highest routing_score; earliest eligible candidate wins ties",
    "no_legal_target": "fizzle",
    "backfire": "hostile backfires onto caster team; beneficial backfires away from caster team",
    "anti_loop": "one reflection only; selected target reflect is suppressed and reported"
  },
  "scenarios": [
    {
      "scenario_id": "t8xsr_hostile_spell_bounces_to_caster_team",
      "model": "spell_routing_reflect",
      "spell": {
        "intent": "hostile",
        "caster_team": "player",
        "reflectable": true,
        "original_target_id": "enemy_reflector",
        "reflection_candidates": [
          {
            "target_id": "player_caster",
            "routing_score": 80
          }
        ]
      },
      "units": [
        {
          "unit_id": "enemy_reflector",
          "team": "enemy",
          "has_reflect": true
        },
        {
          "unit_id": "player_caster",
          "team": "player",
          "has_reflect": false
        }
      ],
      "expected": {
        "reflect_triggered": true,
        "final_target_id": "player_caster",
        "final_team": "player",
        "fizzled": false,
        "eligible_reflection_count": 1,
        "selected_routing_score": 80,
        "hostile_backfire": true,
        "beneficial_backfire": false,
        "secondary_reflect_suppressed": false
      }
    },

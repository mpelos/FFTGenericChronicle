  ],
  "formula_contract": {
    "normalization": "single_resource_pool_per_encounter_sequence",
    "bounds": "resource is clamped to [0, max_resource]",
    "effective_cost": "max(min_cost, ceil(round(base_cost * product(scenario cost_multipliers) * product(event cost_multipliers), 6)))",
    "cost_rounding": "all multipliers apply before one final round(..., 6) and ceil",
    "cast_success": "current_resource >= effective_cost",
    "cast_failure": "resource unchanged and refund_on_success skipped",
    "recovery": "flat_amount + floor(max_resource * percent_of_max), capped at max_resource with overcap_lost",
    "drain": "recover min(drain_amount, target_resource), capped at max_resource",
    "resource_damage": "lose min(current_resource, amount)",
    "reference_casts": "floor(ending_resource / reference_effective_cost)",
    "numeric_comparison": {
      "float_decimals": 6
    }
  },
